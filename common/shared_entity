var SpecProps = map[string]*Attribute{}
var CollectionsURLAttr *Attribute
var CollectionsCountAttr *Attribute
var CollectionsAttr *Attribute

func init() {
	// Load map via lower-case version of prop name
	for _, sp := range OrderedSpecProps {
		SpecProps[sp.Name] = sp
	}

	for _, sp := range PropsFuncs {
		prop := SpecProps[sp.Name]
		PanicIf(prop == nil, "can't be nil")

		if sp.internals != nil {
			if prop.internals == nil {
				prop.internals = &AttrInternals{}
			}
			prop.internals.getFn = sp.internals.getFn
			prop.internals.checkFn = sp.internals.checkFn
			prop.internals.updateFn = sp.internals.updateFn
		}
	}

	CollectionsAttr = SpecProps["$COLLECTIONS"]

	CollectionsURLAttr = &Attribute{
		Name:      "$COLLECTIONSurl",
		Type:      URL,
		ReadOnly:  true,
		Immutable: true,
		Required:  true,
		internals: &AttrInternals{
			types:     StrTypes(ENTITY_REGISTRY, ENTITY_GROUP, ENTITY_RESOURCE),
			dontStore: true,
		},
	}

	CollectionsCountAttr = &Attribute{
		Name:     "$COLLECTIONScount",
		Type:     UINTEGER,
		ReadOnly: true,
		Required: true,
		internals: &AttrInternals{
			types:     StrTypes(ENTITY_REGISTRY, ENTITY_GROUP, ENTITY_RESOURCE),
			dontStore: true,
		},
	}
}

func StrTypes(types ...int) string {
	res := strings.Builder{}
	for _, eType := range types {
		res.WriteByte('0' + byte(eType))
	}
	return res.String()
}

func (e *Entity) GetModels() (*GroupModel, *ResourceModel) {
	if e.GroupModel != nil {
		return e.GroupModel, e.ResourceModel
	}

	if e.Type == ENTITY_REGISTRY || e.Type == ENTITY_MODEL {
		return nil, nil
	}

	e.GroupModel, e.ResourceModel = AbstractToModels(e.Registry, e.Abstract)
	return e.GroupModel, e.ResourceModel
}

func LoadRemoteRegistry(url string) (*Registry, *XRError) {
	url = strings.TrimSpace(url)
	if url == "" {
		return nil, NewXRError("client_error", "", "No Server address provided")
	}

	if !strings.HasPrefix(url, "http") {
		url = "http://" + strings.TrimLeft(url, "/")
	}

	reg := &Registry{
		Entity: Entity{
			Type:     ENTITY_REGISTRY,
			Path:     "", // [GROUPS/gID[/RESOURCES/rID[/versions/vID]]]
			Abstract: "", // [GROUPS[/RESOURCES[/versions]]]
		},
	}

	rootObj := map[string]json.RawMessage(nil)

	// Download model
	data, err := DownloadURL(url + "/model")
	if err != nil {
		data, err2 := DownloadURL(url + "?inline=model,capabilities")
		if err2 != nil {
			return nil, NewXRError("bad_request",
				url+"?inline=model,capabilities",
				"error_detail="+
					fmt.Sprintf("Error getting (%s/model: %s", url, err))
		}

		err = json.Unmarshal(data, &rootObj)
		if err != nil {
			return nil, NewXRError("parsing_response", url,
				"error_detail="+
					fmt.Sprintf("Error parsing Registry root(%s): %s", url,
						err))
		}
		tmp, ok := rootObj["model"]
		if !ok {
			return nil, NewXRError("bad_request", url,
				"error_detail="+
					fmt.Sprintf("Unable to find the model for %q from either "+
						"/model or the \"model\" attribute", url))
		}
		data = []byte(tmp)
	}

	var xErr *XRError
	reg.Model, xErr = ParseModel(data, reg)
	if xErr != nil {
		return nil, xErr.SetDetail("Model:\n" + string(data) + ".")
	}

	// Download capabilities
	data, err = DownloadURL(url + "/capabilities")
	if err != nil {
		if rootObj == nil {
			data, err2 := DownloadURL(url + "?inline=capabilities")
			if err2 != nil {
				return nil, NewXRError("bad_request",
					url+"?inline=capabilities",
					"error_detail="+
						fmt.Sprintf("Error getting capabilities "+
							"(%s/capabilities): %s", url, err))
			}

			err = json.Unmarshal(data, &rootObj)
			if err != nil {
				return nil, NewXRError("parsing_response", url,
					"error_detail="+
						fmt.Sprintf("Error parsing Registry root(%s): %s", url,
							err))
			}
		}
		tmp, ok := rootObj["capabilities"]
		if !ok {
			return nil, NewXRError("bad_request", url,
				"error_detail="+
					fmt.Sprintf("Unable to find the capabilities for %q "+
						"from either /capabilities or the \"capabilities\" "+
						"attribute", url))
		}
		data = []byte(tmp)
	}

	reg.Capabilities, xErr = ParseCapabilities(data)
	if xErr != nil {
		return nil, xErr
	}

	reg.Entity.Registry = reg
	reg.SetStuff("server", url)

	reg.oldCapabilities = reg.Capabilities.Clone()

	return reg, nil
}

// SpecAttrInfo carries the name and entity-type membership for one spec-defined attribute.
// Types is the StrTypes string: "0"=Registry, "1"=Group, "2"=Resource, "3"=Meta, "4"=Version;
// empty string means the attribute applies to all entity types.
type SpecAttrInfo struct {
	Name        string
	Types       string
	UIMonospace bool
	UILabel     string
}

// GetOrderedSpecAttrTypes returns name+types for every entry in
// OrderedSpecProps, in declaration order. Used by cmds/genspecattrs to
// generate registry/ui/specattrs.js.
//
// Note: nested attributes of spec-defined complex (object) attrs — e.g.
// "deprecated"'s effective/removal/alternative/documentation — are NOT
// enumerated here. Their types are already fully described in the runtime
// /model response (which the UI caches per-server), so the UI resolves
// monospace formatting for nested fields by walking that cached model at
// render time (see getExplicitAttrTypeAtPath() in registry/ui/app.js)
// rather than via codegen — this keeps nested-field handling generic for
// any current or future spec-defined (or model-defined extension) complex
// attribute, without hardcoding attribute names here.
func GetOrderedSpecAttrTypes() []SpecAttrInfo {
	result := make([]SpecAttrInfo, 0, len(OrderedSpecProps))
	for _, attr := range OrderedSpecProps {
		types := ""
		mono := false
		label := ""
		if attr.internals != nil {
			types = attr.internals.types
			mono = attr.internals.uiMonospace
			label = attr.internals.uiLabel
		}
		result = append(result, SpecAttrInfo{Name: attr.Name, Types: types, UIMonospace: mono, UILabel: label})
	}
	return result
}
